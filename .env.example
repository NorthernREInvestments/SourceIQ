# SourceIQ environment template — copy to .env and fill in values
# NEVER commit .env to version control

# Admin dashboard (HTTP Basic Auth — any username, password = ADMIN_PASSWORD)
ADMIN_PASSWORD=

# Web app
SECRET_KEY=
APP_BASE_URL=https://sourceiq.up.railway.app
RAILWAY_ENVIRONMENT=

# ScrapingBee (required for Stage 2)
SCRAPINGBEE_API_KEY=
USER_SCRAPINGBEE_API_KEY=

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STARTER_PRICE_ID=
PRO_PRICE_ID=

# SendGrid email
SENDGRID_API_KEY=
FROM_EMAIL=noreply@sourceiq.app

# Optional developer API keys (CLI)
REDDIT_DEV_CLIENT_ID=
REDDIT_DEV_SECRET=
EBAY_DEV_APP_ID=
ETSY_DEV_API_KEY=

# Optional user API keys
REDDIT_USER_CLIENT_ID=
REDDIT_USER_SECRET=
EBAY_USER_APP_ID=
ETSY_USER_API_KEY=

# Optional
FLYBYAPIS_KEY=
SOURCEIQ_TIER=trial
# Set DEBUG_MODE=true locally to write scraper HTML snapshots to output/debug/
DEBUG_MODE=
