# SourceIQ environment template — copy to .env and fill in values
# NEVER commit .env to version control

# Admin dashboard (HTTP Basic Auth — ADMIN_USERNAME + ADMIN_PASSWORD)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Web app
SECRET_KEY=
DATABASE_URL=
APP_BASE_URL=https://sourceiq.up.railway.app
RAILWAY_ENVIRONMENT=

# ScrapingBee (required for Stage 2)
SCRAPINGBEE_API_KEY=
SCRAPINGBEE_REQUEST_TIMEOUT=90
USER_SCRAPINGBEE_API_KEY=

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Optional: set STRIPE_TEST_MODE=true to force test checkout (not required if STRIPE_SECRET_KEY is sk_test_...)
STRIPE_TEST_MODE=false
STRIPE_TEST_PRICE_ID=
# Optional display price for marketing pages (e.g. 29.99)
SUBSCRIPTION_PRICE_DISPLAY=29.99

# Optional fill-missing tuning
# FILL_MISSING_PRODUCT_PAUSE_SEC=1.5

# Resend email
RESEND_API_KEY=
FROM_EMAIL=noreply@sourceiq.app

# Optional developer API keys (CLI)
REDDIT_DEV_CLIENT_ID=
REDDIT_DEV_SECRET=
EBAY_DEV_APP_ID=
ETSY_DEV_API_KEY=

# Optional user API keys
REDDIT_USER_CLIENT_ID=
REDDIT_USER_SECRET=
EBAY_USER_APP_ID=
ETSY_USER_API_KEY=

# Optional
FLYBYAPIS_KEY=
SOURCEIQ_TIER=trial
# Set DEBUG_MODE=true locally to write scraper HTML snapshots to output/debug/
DEBUG_MODE=
